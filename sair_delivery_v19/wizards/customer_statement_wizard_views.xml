<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_customer_statement_wizard_form" model="ir.ui.view">
        <field name="name">sair.customer.statement.wizard.form</field>
        <field name="model">sair.customer.statement.wizard</field>
        <field name="arch" type="xml">
            <form string="كشف رحلات عميل">
                <group>
                    <field name="customer_id"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <separator string="نوع الكشف"/>
                    <field name="report_type" widget="radio"/>
                </group>
                <footer>
                    <button name="action_print" string="طباعة الكشف"
                            type="object" class="btn-primary"/>
                    <button string="إلغاء" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_customer_statement_wizard" model="ir.actions.act_window">
        <field name="name">كشف رحلات عميل</field>
        <field name="res_model">sair.customer.statement.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
